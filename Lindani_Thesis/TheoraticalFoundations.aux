\@writefile{lof}{\contentsline {figure}{\numberline {7.4}{\ignorespaces Internal dataflow of a GRU cell at time step $t$. The update gate $\mathbf  {z}_t$ interpolates between the previous state $\mathbf  {h}_{t-1}$ (weighted by $1 - \mathbf  {z}_t$) and the candidate $\tilde  {\mathbf  {h}}_t$ (weighted by $\mathbf  {z}_t$). The reset gate $\mathbf  {r}_t$ controls how much of $\mathbf  {h}_{t-1}$ enters the candidate computation. The near-direct path from $\mathbf  {h}_{t-1}$ to $\mathbf  {h}_t$ when $\mathbf  {z}_t \approx 0$ is the mechanism that prevents gradient vanishing across long sequences.}}{65}{figure.caption.24}\protected@file@percent }
\newlabel{fig:gru_cell}{{7.4}{65}{Internal dataflow of a GRU cell at time step $t$. The update gate $\mathbf {z}_t$ interpolates between the previous state $\mathbf {h}_{t-1}$ (weighted by $1 - \mathbf {z}_t$) and the candidate $\tilde {\mathbf {h}}_t$ (weighted by $\mathbf {z}_t$). The reset gate $\mathbf {r}_t$ controls how much of $\mathbf {h}_{t-1}$ enters the candidate computation. The near-direct path from $\mathbf {h}_{t-1}$ to $\mathbf {h}_t$ when $\mathbf {z}_t \approx 0$ is the mechanism that prevents gradient vanishing across long sequences}{figure.caption.24}{}}
